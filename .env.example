# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/alertproche

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# App
PORT=3000
FRONTEND_URL=https://alert-proche.vercel.app

# ─── CLOUDINARY ────────────────────────────────────────────────────
# 1. Créer un compte gratuit sur https://cloudinary.com
# 2. Dashboard → Settings → API Keys
# 3. Copier Cloud Name, API Key et API Secret ci-dessous
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=alertproche/posts
